@model DBConnection.Models.LoginViewModel

@{
    ViewData["Title"] = "Login";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        body {
            background-color: #f4f6f9;
        }

        .custom-header {
            background: linear-gradient(135deg, #1a252f, #2c3e50);
        }
    </style>
</head>
<body>

    <div class="container my-5">
        <div class="row justify-content-center pt-5">
            <div class="col-lg-4 col-md-7 col-sm-10">
                <div class="card shadow-lg border-0 rounded-3 overflow-hidden">

                    <div class="card-header text-white p-4 custom-header">
                        <div class="d-flex align-items-center gap-3">
                            <div class="flex-shrink-0">
                                <img src="/Image/Logo.png" alt="Logo" style="height: 50px; width: auto; object-fit: contain;" />
                            </div>
                            <div>
                                <h4 class="mb-0 fw-bold tracking-tight" style="color: #3498db;">Online Tuition System</h4>
                                <p class="text-white-50 small mb-0">Sign in to access your portal</p>
                            </div>
                        </div>
                    </div>

                    <div class="card-body p-4 bg-white">

                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div class="alert alert-danger p-2 small mb-3">
                                <div asp-validation-summary="All" class="mb-0"></div>
                            </div>
                        }

                        <form asp-action="Login" method="post" autocomplete="off">
                            <div class="mb-3">
                                <label class="form-label fw-semibold text-secondary small mb-1">Email Address</label>
                                <input type="email" name="Email" class="form-control border-secondary-subtle" placeholder="name@example.com" required />
                            </div>

                            <div class="mb-4">
                                <label class="form-label fw-semibold text-secondary small mb-1">Password</label>
                                <input type="password" name="Password" class="form-control border-secondary-subtle" placeholder="Enter account password" required />
                            </div>

                            <button type="submit" class="btn btn-primary w-100 fw-bold py-2 rounded-2 shadow-sm mb-3 text-uppercase border-0" style="background-color: #3498db;">
                                Login
                            </button>

                            <div class="text-center pt-2 border-top border-light">
                                <span class="text-muted small">Don't have an account?</span>
                                <a asp-action="Index" class="text-decoration-none small fw-bold ms-1" style="color: #3498db;">Register here</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

</body>
</html>