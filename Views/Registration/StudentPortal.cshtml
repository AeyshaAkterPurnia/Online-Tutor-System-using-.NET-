@{
    ViewData["Title"] = "Student Portal";
}

<div class="container mt-5">
    <div class="card shadow border-0">
        <div class="card-header bg-success text-white py-3">
            <h2 class="mb-0 fw-bold">🎓 Student Dashboard</h2>
        </div>
        <div class="card-body p-4">
            <h3>Welcome to your Portal!</h3>
            <p class="text-muted">You have successfully logged into the Online Tuition System using a Student Account.</p>
            <hr />
            <div class="row mt-4">
                <div class="col-md-4 mb-3">
                    <div class="p-3 bg-light border rounded">
                        <h5>My Courses</h5>
                        <p class="text-muted small">View your active tuitions and classes.</p>
                    </div>
                </div>
                <div class="col-md-4 mb-3">
                    <div class="p-3 bg-light border rounded">
                        <h5>Assignments</h5>
                        <p class="text-muted small">Check pending tasks submitted by your teacher.</p>
                    </div>
                </div>
                <div class="col-md-4 mb-3">
                    <div class="p-3 bg-light border rounded">
                        <h5>Schedule</h5>
                        <p class="text-muted small">View upcoming session timings.</p>
                    </div>
                </div>
            </div>
            <a asp-action="Login" class="btn btn-outline-danger btn-sm mt-3">Logout</a>
        </div>
    </div>
</div>